PROD=PROD_FLAG
NODE=NODE_NAME
MASTER=MASTER_FLAG
PROC_N=3

# Enabled kline settings
# Format: LOCAL_MARKET/QUOTE:FOREIGN_MARKET/QUOTE
# Available markets: BINANCE_USD_M, BINANCE_COIN_M, OKX_USD_M, BYBIT_USD_M, GATE_USD_M, HYPERLIQUID_USD_M
# Available local: UPBIT_SPOT, BITHUMB_SPOT, COINONE_SPOT
# Note: HYPERLIQUID uses USDC (not USDT)
ENABLED_MARKET_KLINES="
UPBIT_SPOT/KRW:BINANCE_USD_M/USDT,
"

# This will be only executed in the master node
ENALBED_ARBITRAGE_MARKETS="
UPBIT_SPOT/KRW:BINANCE_USD_M/USDT,
"

# database settings
MONGODB_HOST=MONGODB_HOST
MONGODB_PORT=MONGODB_PORT
MONGODB_USER=MONGODB_USER
MONGODB_PASS=MONGODB_PASS
REDIS_HOST=REDIS_HOST
REDIS_PORT=REDIS_PORT
REDIS_PASS=REDIS_PASS
POSTGRES_HOST=POSTGRES_HOST
POSTGRES_PORT=POSTGRES_PORT
POSTGRES_USER=POSTGRES_USER
POSTGRES_PASS=POSTGRES_PASS

# monitor settings
ADMIN_TELEGRAM_ID=ADMIN_TELEGRAM_ID
STAFF_TELEGRAM_ID_LIST=STAFF_TELEGRAM_ID1,STAFF_TELEGRAM_ID2
MONITOR_BOT_TOKEN=MONITOR_BOT_TOKEN
MONITOR_BOT_API_URL=MONITOR_BOT_API_URL

# acw settings
ACW_API_URL=ACW_API_URL

# read only API key for fetching data from exchanges
BINANCE_ACCESS_KEY=BINANCE_ACCESS_KEY
BINANCE_SECRET_KEY=BINANCE_SECRET_KEY
OKX_ACCESS_KEY=OKX_ACCESS_KEY
OKX_SECRET_KEY=OKX_SECRET_KEY
OKX_PASSPHRASE=OKX_PASSPHRASE
UPBIT_ACCESS_KEY=UPBIT_ACCESS_KEY
UPBIT_SECRET_KEY=UPBIT_SECRET_KEY
BITHUMB_ACCESS_KEY=BITHUMB_ACCESS_KEY
BITHUMB_SECRET_KEY=BITHUMB_SECRET_KEY
BYBIT_ACCESS_KEY=BYBIT_ACCESS_KEY
BYBIT_SECRET_KEY=BYBIT_SECRET_KEY
GATE_ACCESS_KEY=GATE_ACCESS_KEY
GATE_SECRET_KEY=GATE_SECRET_KEY

# Hyperliquid (DEX) - No API keys required for public market data
# Just add HYPERLIQUID_USD_M/USDC to ENABLED_MARKET_KLINES to enable

# Optional, AIENGINE_API_KEY for GPT API
AIENGINE_API_KEY=AIENGINE_API_KEY

