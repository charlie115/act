{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "src/*": ["./"],
      "assets/*": ["./assets/*"],
      "components/*": ["./components/*"],
      "configs/*": ["./configs/*"],
      "pages/*": ["./pages/*"],
      "store/*": ["./store/*"]
    },
    "target": "es6",
    "moduleResolution": "classic",
    "jsx": "react"
  },
  "include": ["src/**/*"]
}
